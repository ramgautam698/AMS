{
  "compilerOptions":
  {
    "baseUrl": ".",
    "paths": {
        "@/*": ["./src/*"]
    },
    "jsx": "react", // react-jsx -> For React 17+ (with automatic JSX runtime)
    "noEmit": true, // Prevents TypeScript from emitting JS files
    "strict": true, // Optionally enable strict mode
    "module": "ESNext", // Ensure compatibility with Vite
    "target": "ESNext",
    "allowSyntheticDefaultImports": true, // Allow default imports
  },
  "include": ["src/**/*"], // Include your source files
  "exclude": ["node_modules", "dist", "build"] // Exclude directories to prevent infinite loop
}

